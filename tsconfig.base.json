{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ng-highcharts/knowledge-base": ["libs/knowledge-base/src/index.ts"],
      "@ng-highcharts/shared": ["libs/shared/src/index.ts"],
      "@ng-highcharts/todo-tracker": ["libs/todo-tracker/src/index.ts"],
      "@ng-highcharts/tracker": ["libs/tracker/src/index.ts"],
      "@ng-highcharts/training": ["libs/training/src/index.ts"]
    }
  }
}
